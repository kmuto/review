#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'

$LOAD_PATH.unshift(File.realpath('../lib', __dir__))

require 'compat/runner'

options = {}

OptionParser.new do |opts|
  opts.banner = 'Usage: check-compat [options]'
  opts.version = '1.0.0'

  opts.on('-f', '--format FORMAT', 'Check format (html, latex, all)', 'Default: all') do |f|
    unless %w[html latex all].include?(f)
      puts "Error: Invalid format '#{f}'. Must be one of: html, latex, all"
      exit 1
    end
    options[:format] = f
  end

  opts.on('-d', '--dir DIR', 'Fixtures directory', 'Default: fixtures/compat') do |d|
    options[:fixtures_dir] = d
  end

  opts.on('-o', '--output DIR', 'Output directory', 'Default: reports/compat') do |o|
    options[:output_dir] = o
  end

  opts.on('-v', '--verbose', 'Verbose output') do
    options[:verbose] = true
  end

  opts.on('--sequential', 'Run checks sequentially (not parallel)') do
    options[:parallel] = false
  end

  opts.on('-p', '--pattern PATTERN', 'File pattern to check', 'Default: **/*.re') do |p|
    options[:pattern] = p
  end

  opts.on('--show-diff', 'Show detailed differences') do
    options[:show_diff] = true
  end

  opts.on('-h', '--help', 'Show this help message') do
    puts opts
    exit
  end
end.parse!

begin
  runner = ReVIEW::Compat::Runner.new(options)
  exit_code = runner.run
  exit(exit_code)
rescue StandardError => e
  puts "Error: #{e.message}"
  puts e.backtrace.join("\n") if options[:verbose]
  exit 1
end
